<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NextLevel Marketing – Wir bringen dein Business aufs nächste Level</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080808;
  --surface:#0f0f0f;
  --surface2:#141414;
  --border:#1e1e1e;
  --blue:#2563eb;
  --blue-light:#3b82f6;
  --blue-glow:rgba(37,99,235,0.25);
  --text:#f0f0f0;
  --muted:#888;
  --muted2:#444;
  --font-d:'Syne',sans-serif;
  --font-b:'DM Sans',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-b);font-weight:300;overflow-x:hidden;cursor:none}

/* CURSOR */
#cur{width:10px;height:10px;background:var(--blue-light);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9999;transform:translate(-50%,-50%)}
#cur-r{width:34px;height:34px;border:1px solid rgba(59,130,246,.3);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:all .13s ease-out}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:1rem 4rem;transition:background .3s,border-color .3s;border-bottom:1px solid transparent}
nav.scrolled{background:rgba(8,8,8,.94);backdrop-filter:blur(24px);border-color:var(--border)}
.nav-logo img{height:38px;width:auto;display:block}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--text)}
.nav-right{display:flex;align-items:center;gap:1.2rem}
.nav-ig{display:flex;align-items:center;gap:.5rem;font-size:.78rem;color:var(--muted);text-decoration:none;transition:color .2s;letter-spacing:.03em}
.nav-ig:hover{color:var(--blue-light)}
.nav-ig svg{width:16px;height:16px;fill:none;stroke:currentColor;stroke-width:1.5}
.nav-btn{background:var(--blue);color:#fff;font-family:var(--font-d);font-weight:700;font-size:.78rem;letter-spacing:.05em;padding:.55rem 1.3rem;border-radius:6px;text-decoration:none;transition:all .2s}
.nav-btn:hover{background:var(--blue-light);box-shadow:0 0 20px var(--blue-glow)}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:9rem 2rem 6rem;position:relative;overflow:hidden;background-image:url('data:image/png;base64,');background-size:cover;background-position:center top;background-repeat:no-repeat}
.hero::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(8,8,8,.55) 0%,rgba(8,8,8,.35) 40%,rgba(8,8,8,.75) 85%,rgba(8,8,8,1) 100%);z-index:0}
.hero-glow{position:absolute;top:-10%;left:50%;transform:translateX(-50%);width:900px;height:700px;background:radial-gradient(ellipse,rgba(37,99,235,.08) 0%,transparent 65%);pointer-events:none;z-index:1}
.hero-grid{display:none}
.hero-bottom-line{position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent);z-index:2}
.hero-logo{margin-bottom:1.5rem;position:relative;z-index:2}
.hero-logo img{height:140px;width:auto}
.hero-tag{display:inline-flex;align-items:center;gap:.5rem;border:1px solid var(--border);background:rgba(15,15,15,.8);padding:.35rem .9rem;border-radius:100px;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;position:relative;z-index:2}
.hero-tag .dot{width:6px;height:6px;background:var(--blue-light);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}
.hero h1{font-family:var(--font-d);font-size:clamp(2.8rem,7.5vw,6.5rem);font-weight:800;line-height:.88;letter-spacing:-.04em;position:relative;z-index:2;margin-bottom:1rem}
.hero h1 em{font-style:normal;color:var(--blue-light)}
.hero-sub{font-size:1.05rem;color:var(--muted);max-width:500px;line-height:1.6;position:relative;z-index:2;margin-bottom:2rem}
.hero-sub strong{color:var(--text);font-weight:500}
.hero-btns{display:flex;gap:1rem;position:relative;z-index:2;justify-content:center;flex-wrap:wrap}
.btn-primary{background:var(--blue);color:#fff;font-family:var(--font-d);font-weight:700;font-size:.88rem;padding:.8rem 1.8rem;border-radius:8px;text-decoration:none;transition:all .2s;box-shadow:0 0 30px rgba(37,99,235,.25);display:inline-flex;align-items:center;gap:.5rem}
.btn-primary:hover{background:var(--blue-light);box-shadow:0 0 40px rgba(59,130,246,.4);transform:translateY(-2px)}
.btn-secondary{border:1px solid var(--border);color:var(--text);font-family:var(--font-d);font-weight:600;font-size:.88rem;padding:.8rem 1.8rem;border-radius:8px;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:.5rem}
.btn-secondary:hover{border-color:var(--blue);color:var(--blue-light)}
.hero-stats{display:flex;gap:3.5rem;margin-top:3rem;position:relative;z-index:2;padding-top:2rem;border-top:1px solid var(--border);flex-wrap:wrap;justify-content:center}
.stat-num{font-family:var(--font-d);font-size:2rem;font-weight:800;color:var(--blue-light)}
.stat-label{font-size:.72rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:.2rem}

/* INSTAGRAM BANNER */






/* SECTIONS */
section{padding:6rem 4rem}
.container{max-width:1200px;margin:0 auto}
.section-tag{font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;color:var(--blue-light);margin-bottom:.75rem;font-weight:500}
.section-title{font-family:var(--font-d);font-size:clamp(1.7rem,3.5vw,2.8rem);font-weight:800;line-height:1.05;letter-spacing:-.025em;margin-bottom:1rem}
.section-sub{color:var(--muted);font-size:.95rem;line-height:1.75;max-width:500px}

/* SERVICES */
.services{background:var(--surface);background-image:url('data:image/png;base64,');background-size:cover;background-position:center;background-repeat:no-repeat;position:relative}
.services::before{content:'';position:absolute;inset:0;background:rgba(8,8,8,.72);z-index:0}
.services .container{position:relative;z-index:1}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-top:3.5rem;background:var(--border);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.service-card{background:var(--bg);padding:2.2rem;transition:background .25s;position:relative;overflow:hidden}
.service-card::after{content:'';position:absolute;bottom:0;left:2.2rem;right:2.2rem;height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent);opacity:0;transition:opacity .3s}
.service-card:hover{background:#0d0d0d}
.service-card:hover::after{opacity:.6}
.s-icon{width:44px;height:44px;margin-bottom:1.3rem;display:flex;align-items:center;justify-content:center;border:1px solid var(--border);border-radius:10px;color:var(--blue-light);transition:all .25s}.service-card:hover .s-icon{border-color:var(--blue);box-shadow:0 0 14px var(--blue-glow)}.s-icon svg{width:22px;height:22px}
.service-card h3{font-family:var(--font-d);font-size:1rem;font-weight:700;margin-bottom:.65rem;letter-spacing:-.01em}
.service-card p{font-size:.83rem;color:var(--muted);line-height:1.6;margin-bottom:1rem}
.service-card ul{list-style:none;display:flex;flex-direction:column;gap:.35rem}
.service-card ul li{font-size:.78rem;color:var(--muted2);display:flex;align-items:center;gap:.5rem}
.service-card ul li::before{content:'';width:4px;height:4px;background:var(--blue-light);border-radius:50%;flex-shrink:0}

/* PAKETE */
.pakete{background:var(--bg);background-image:url('data:image/png;base64,');background-size:cover;background-position:center;background-repeat:no-repeat;position:relative}
.pakete::before{content:'';position:absolute;inset:0;background:rgba(8,8,8,.80);z-index:0}
.pakete .container{position:relative;z-index:1}
.pakete-intro{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:2rem;margin-bottom:3rem}
.pakete-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
.paket{border:1px solid var(--border);border-radius:14px;padding:2.2rem;background:var(--surface);position:relative;transition:all .3s;overflow:hidden;display:flex;flex-direction:column}
.paket:hover{border-color:rgba(37,99,235,.5);transform:translateY(-3px);box-shadow:0 16px 50px rgba(37,99,235,.07)}
.paket.featured{border-color:var(--blue);background:var(--surface2);box-shadow:0 0 40px rgba(37,99,235,.1)}
.paket.featured::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--blue),var(--blue-light))}
.p-badge{display:inline-flex;align-items:center;gap:.4rem;font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;padding:.28rem .75rem;border-radius:100px;margin-bottom:1.3rem;font-weight:600}
.b-starter{background:rgba(37,99,235,.1);color:#7da9f8;border:1px solid rgba(37,99,235,.2)}
.b-growth{background:rgba(59,130,246,.14);color:#93c5fd;border:1px solid rgba(59,130,246,.28)}
.b-scale{background:rgba(37,99,235,.18);color:#fff;border:1px solid rgba(37,99,235,.5)}
.paket h3{font-family:var(--font-d);font-size:1.55rem;font-weight:800;letter-spacing:-.025em;margin-bottom:.45rem}
.paket-sub{font-size:.82rem;color:var(--muted);margin-bottom:1.5rem;line-height:1.55}
.paket hr{border:none;border-top:1px solid var(--border);margin-bottom:1.4rem}
.paket-features{list-style:none;display:flex;flex-direction:column;gap:.7rem;margin-bottom:1.8rem;flex:1}
.paket-features li{display:flex;align-items:flex-start;gap:.7rem;font-size:.82rem;color:var(--muted);line-height:1.45}
.chk{width:15px;height:15px;border-radius:50%;background:rgba(37,99,235,.12);border:1px solid rgba(59,130,246,.4);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.1rem;color:var(--blue-light);font-size:.55rem}
.p-btn{display:block;text-align:center;padding:.75rem;border-radius:8px;font-family:var(--font-d);font-weight:700;font-size:.82rem;text-decoration:none;transition:all .2s;letter-spacing:.02em}
.p-btn-outline{border:1px solid var(--border);color:var(--text)}
.p-btn-outline:hover{border-color:var(--blue);color:var(--blue-light)}
.p-btn-solid{background:var(--blue);color:#fff;box-shadow:0 0 20px var(--blue-glow)}
.p-btn-solid:hover{background:var(--blue-light);box-shadow:0 0 30px rgba(59,130,246,.35)}

/* PROCESS */
.process{background:var(--surface);background-image:url('data:image/png;base64,');background-size:cover;background-position:center;background-repeat:no-repeat;position:relative}
.process::before{content:'';position:absolute;inset:0;background:rgba(8,8,8,.78);z-index:0}
.process .container{position:relative;z-index:1}
.steps{display:grid;grid-template-columns:repeat(6,1fr);gap:1rem;margin-top:3.5rem;position:relative}
.steps::before{content:'';position:absolute;top:27px;left:calc(100%/12);right:calc(100%/12);height:1px;background:linear-gradient(90deg,transparent,var(--border) 15%,var(--blue-light) 50%,var(--border) 85%,transparent)}
.step{display:flex;flex-direction:column;align-items:center;text-align:center;position:relative}
.step-n{width:54px;height:54px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-d);font-size:.78rem;font-weight:700;color:var(--muted);background:var(--bg);margin-bottom:.9rem;transition:all .25s}
.step:hover .step-n{border-color:var(--blue);color:var(--blue-light);box-shadow:0 0 18px var(--blue-glow)}
.step h4{font-family:var(--font-d);font-size:.82rem;font-weight:700;margin-bottom:.35rem}
.step p{font-size:.73rem;color:var(--muted);line-height:1.5}

/* WHY */
.why{background:var(--bg);background-image:url('data:image/jpeg;base64,');background-size:cover;background-position:center;background-repeat:no-repeat;position:relative}
.why::before{content:'';position:absolute;inset:0;background:rgba(8,8,8,.75);z-index:0}
.why .container{position:relative;z-index:1}
.why-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;margin-top:3.5rem}
.why-list{display:flex;flex-direction:column;gap:1.8rem}
.why-item{display:flex;gap:1.3rem}
.w-icon{width:42px;height:42px;border:1px solid var(--border);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;transition:all .25s}
.why-item:hover .w-icon{border-color:var(--blue);box-shadow:0 0 14px var(--blue-glow)}
.why-item h4{font-family:var(--font-d);font-size:.95rem;font-weight:700;margin-bottom:.35rem}
.why-item p{font-size:.83rem;color:var(--muted);line-height:1.6}
.metrics-box{border:1px solid var(--border);border-radius:14px;background:var(--surface);padding:2.2rem;position:relative;overflow:hidden}
.metrics-box::before{content:'';position:absolute;top:-60%;right:-40%;width:280px;height:280px;background:radial-gradient(circle,rgba(37,99,235,.09) 0%,transparent 70%)}
.metric{margin-bottom:1.4rem}
.metric:last-child{margin-bottom:0}
.m-top{display:flex;justify-content:space-between;font-size:.73rem;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;margin-bottom:.45rem}
.m-top span{color:var(--blue-light);font-weight:600}
.m-bar{height:5px;background:var(--border);border-radius:3px;overflow:hidden}
.m-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--blue-light));border-radius:3px;width:0;transition:width 1.4s ease-out}

/* INSTAGRAM SECTION */
.ig-section{text-align:center;padding:5rem 4rem;background-image:url('data:image/jpeg;base64,');background-size:cover;background-position:center;background-repeat:no-repeat;position:relative}
.ig-section::before{content:'';position:absolute;inset:0;background:rgba(8,8,8,.65);z-index:0}
.ig-section .ig-inner{position:relative;z-index:1}
.ig-inner{max-width:600px;margin:0 auto}
.ig-logo-wrap{margin-bottom:1.5rem}
.ig-circle{width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045);display:flex;align-items:center;justify-content:center;margin:0 auto}
.ig-circle svg{width:38px;height:38px;fill:#fff}
.ig-section h2{font-family:var(--font-d);font-size:clamp(1.6rem,3vw,2.4rem);font-weight:800;letter-spacing:-.02em;margin-bottom:.75rem}
.ig-section p{color:var(--muted);font-size:.95rem;line-height:1.7;margin-bottom:2rem}
.ig-handle{font-family:var(--font-d);font-size:1.4rem;font-weight:800;color:var(--text);margin-bottom:1.8rem;letter-spacing:-.01em}
.ig-handle span{background:linear-gradient(135deg,#c084fc,#f472b6,#fb923c);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.ig-btn{display:inline-flex;align-items:center;gap:.7rem;background:linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045);color:#fff;font-family:var(--font-d);font-weight:700;font-size:.92rem;padding:.85rem 2rem;border-radius:8px;text-decoration:none;transition:all .2s;box-shadow:0 0 30px rgba(253,29,29,.2)}
.ig-btn:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(253,29,29,.3)}
.ig-btn svg{width:20px;height:20px;fill:#fff}

/* CTA */
.cta{text-align:center;padding:8rem 4rem;position:relative;overflow:hidden;background-image:url('data:image/jpeg;base64,');background-size:cover;background-position:center;background-repeat:no-repeat}
.cta::after{content:'';position:absolute;inset:0;background:rgba(8,8,8,.72);z-index:0}
.cta::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:500px;background:radial-gradient(ellipse,rgba(37,99,235,.11) 0%,transparent 70%);z-index:1}
.cta-inner{position:relative;z-index:2}
.cta-logo{margin-bottom:2rem}
.cta-logo img{height:60px;width:auto;opacity:.9}
.cta h2{font-family:var(--font-d);font-size:clamp(1.8rem,4.5vw,3.5rem);font-weight:800;line-height:1.02;letter-spacing:-.03em;margin-bottom:1.2rem}
.cta h2 span{color:var(--blue-light)}
.cta p{color:var(--muted);font-size:1rem;max-width:460px;margin:0 auto 2.2rem;line-height:1.7}
.cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.cta-note{margin-top:1.5rem;font-size:.75rem;color:var(--muted2)}

/* FOOTER */
footer{background:var(--surface);border-top:1px solid var(--border);padding:2.5rem 4rem}
.footer-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1.5rem}
.footer-logo img{height:28px;width:auto;opacity:.8}
.f-links{display:flex;gap:2rem;list-style:none}
.f-links a{font-size:.78rem;color:var(--muted2);text-decoration:none;transition:color .2s}
.f-links a:hover{color:var(--text)}
.f-right{display:flex;align-items:center;gap:1.5rem}
.f-ig{display:flex;align-items:center;gap:.4rem;font-size:.78rem;color:var(--muted);text-decoration:none;transition:color .2s}
.f-ig:hover{color:var(--blue-light)}
.f-ig svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:1.5}
.footer-copy{font-size:.75rem;color:var(--muted2)}

.glow-div{height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent)}

/* ANIMATIONS */
.fade-up{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.fade-up.visible{opacity:1;transform:none}

@media(max-width:1024px){
  .pakete-grid,.services-grid{grid-template-columns:1fr}
  .steps{grid-template-columns:repeat(3,1fr)}
  .steps::before{display:none}
  .why-grid{grid-template-columns:1fr}
  nav,section{padding-left:2rem;padding-right:2rem}
  .ig-section{padding:4rem 2rem}
  
  footer{padding:2rem}
}
@media(max-width:768px){
  .nav-links,.nav-btn{display:none}
  .hero-stats{gap:1.5rem}
  .steps{grid-template-columns:repeat(2,1fr)}
  .footer-inner{flex-direction:column;text-align:center}
  .f-links{justify-content:center}
}

/* ÜBER UNS */
.ueber-uns{padding:6rem 4rem;background-image:url('data:image/jpeg;base64,');background-size:cover;background-position:center;background-repeat:no-repeat;position:relative}
.ueber-uns::before{content:'';position:absolute;inset:0;background:rgba(8,8,8,.78);z-index:0}
.ueber-uns .container{position:relative;z-index:1}
.team-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-bottom:2rem}
.team-card{border:1px solid var(--border);border-radius:16px;background:var(--bg);overflow:hidden;display:flex;flex-direction:column;transition:border-color .3s,transform .3s,box-shadow .3s}
.team-card:hover{border-color:rgba(37,99,235,.45);transform:translateY(-4px);box-shadow:0 20px 50px rgba(37,99,235,.08)}
.team-photo-wrap{width:100%;aspect-ratio:4/3;background:var(--surface2);position:relative;overflow:hidden}
.team-photo-wrap img{width:100%;height:100%;object-fit:cover;object-position:top}
.team-photo-placeholder{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.75rem;color:var(--muted2);background:linear-gradient(135deg,var(--surface) 0%,var(--surface2) 100%);border-bottom:1px solid var(--border)}
.team-photo-placeholder span{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted2)}
.team-photo-placeholder svg{opacity:.3}
.team-info{padding:2rem;flex:1;display:flex;flex-direction:column;gap:1rem}
.team-role{font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--blue-light);font-weight:500}
.team-name{font-family:var(--font-d);font-size:1.6rem;font-weight:800;letter-spacing:-.025em;line-height:1}
.team-bio{font-size:.85rem;color:var(--muted);line-height:1.7;flex:1}
.team-tags{display:flex;flex-wrap:wrap;gap:.5rem}
.team-tags span{font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;padding:.28rem .7rem;border-radius:100px;border:1px solid var(--border);color:var(--muted);background:var(--surface2)}
.team-ig{display:inline-flex;align-items:center;gap:.5rem;font-size:.78rem;color:var(--muted);text-decoration:none;transition:color .2s;margin-top:.25rem}
.team-ig:hover{color:var(--blue-light)}
.mission-box{border:1px solid var(--border);border-radius:16px;background:var(--bg);padding:2.5rem;display:flex;gap:3rem;align-items:center;flex-wrap:wrap}
.mission-quote{display:flex;gap:1.2rem;align-items:flex-start;flex:1;min-width:280px}
.mission-quote p{font-size:.95rem;color:var(--muted);line-height:1.75;font-style:italic}
.mission-stats{display:flex;align-items:center;gap:2rem;flex-shrink:0}
.m-stat{display:flex;flex-direction:column;align-items:center;text-align:center}
.m-stat-num{font-family:var(--font-d);font-size:1.6rem;font-weight:800;color:var(--blue-light)}
.m-stat-label{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:.2rem}
.m-stat-div{width:1px;height:40px;background:var(--border)}
@media(max-width:768px){.team-grid{grid-template-columns:1fr}.mission-box{flex-direction:column}.mission-stats{width:100%;justify-content:center}}
</style>
</head>
<body>
<div id="cur"></div>
<div id="cur-r"></div>

<!-- NAV -->
<nav id="nav">
  <a href="#" class="nav-logo">
    <img src="data:image/png;base64," alt="NextLevel Marketing"/>
  </a>
  <ul class="nav-links">
    <li><a href="#leistungen">Leistungen</a></li>
    <li><a href="#pakete">Pakete</a></li>
    <li><a href="#prozess">Prozess</a></li>
    <li><a href="#ueber-uns">Über uns</a></li><li><a href="#instagram">Instagram</a></li>
    <li><a href="#kontakt">Kontakt</a></li>
  </ul>
  <div class="nav-right">
    <a href="https://www.instagram.com/marketingbynextlevel/" target="_blank" class="nav-ig">
      <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
      @marketingbynextlevel
    </a>
    <a href="#kontakt" class="nav-btn">Kostenlos anfragen</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-glow"></div>
  <div class="hero-grid"></div>
  <div class="hero-logo fade-up">
    <img src="data:image/png;base64," alt="NextLevel Marketing"/>
  </div>
  <div class="hero-tag fade-up"><span class="dot"></span>Social Media Marketing & Service Agentur · Austria</div>
  <h1 class="fade-up">WIR BRINGEN DEIN<br><em>BUSINESS AUFS<br>NÄCHSTE LEVEL.</em></h1>
  <p class="hero-sub fade-up">Mehr <strong>Reichweite</strong>. Mehr <strong>Kunden</strong>. Mehr <strong>Umsatz</strong>.<br>Social Media, Performance Ads, AI-Automation & Webdesign – alles aus einer Hand.</p>
  <div class="hero-btns fade-up">
    <a href="#kontakt" class="btn-primary">Jetzt kostenlos anfragen →</a>
    <a href="#leistungen" class="btn-secondary">Leistungen entdecken</a>
  </div>
  <div class="hero-stats fade-up">
    <div><div class="stat-num">+248%</div><div class="stat-label">Mehr Anfragen</div></div>
    <div><div class="stat-num">+237%</div><div class="stat-label">Mehr Leads (AI)</div></div>
    <div><div class="stat-num">+62%</div><div class="stat-label">Bessere Conversion</div></div>
    <div><div class="stat-num">+35%</div><div class="stat-label">Mehr Umsatz</div></div>
  </div>
  <div class="hero-bottom-line"></div>
</section>

<div class="glow-div"></div>

<!-- LEISTUNGEN -->
<section class="services" id="leistungen">
  <div class="container">
    <div class="fade-up">
      <div class="section-tag">Was wir tun</div>
      <h2 class="section-title">Alles, was dein Business<br>wirklich braucht.</h2>
    </div>
    <div class="services-grid fade-up">
      <div class="service-card">
        <div class="s-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r="1" fill="currentColor" stroke="none"/></svg></div>
        <h3>Social Media Marketing</h3>
        <p>Strategischer Content, der deine Marke sichtbar macht und deine Zielgruppe täglich erreicht.</p>
        <ul>
          <li>Content Strategie & Feed Posts</li><li>Reels & Kurzvideos</li><li>Community Management</li><li>Stories & Hashtag Recherche</li><li>Regelmäßige Betreuung</li>
        </ul>
      </div>
      <div class="service-card">
        <div class="s-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/></svg></div>
        <h3>Performance Ads</h3>
        <p>Gezielte Kampagnen auf Meta & Google, die qualifizierte Anfragen und messbaren ROI liefern.</p>
        <ul>
          <li>Kampagnen Setup & Management</li><li>Zielgruppen-Targeting</li><li>Anzeigen Erstellung & Testing</li><li>Laufende Optimierung</li><li>Maximaler ROI</li>
        </ul>
      </div>
      <div class="service-card">
        <div class="s-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="8" width="18" height="12" rx="2"/><path d="M9 8V6a3 3 0 016 0v2"/><circle cx="9" cy="14" r="1.5" fill="currentColor" stroke="none"/><circle cx="15" cy="14" r="1.5" fill="currentColor" stroke="none"/><path d="M8 18h8"/><line x1="12" y1="2" x2="12" y2="4"/></svg></div>
        <h3>AI Lead Automation</h3>
        <p>Intelligente Systeme, die automatisch Leads generieren, qualifizieren und konvertieren – 24/7.</p>
        <ul>
          <li>AI-gestützte Lead Generierung</li><li>Automatisierte Funnels & CRM</li><li>E-Mail & WhatsApp Automation</li><li>Terminbuchung automatisiert</li><li>Pipeline Management</li>
        </ul>
      </div>
      <div class="service-card">
        <div class="s-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M2 20h20"/><path d="M8 20l1-2M16 20l-1-2"/></svg></div>
        <h3>Webdesign</h3>
        <p>Conversion-optimierte Landingpages, die Besucher zu Kunden machen. Modern. Schnell. Converting.</p>
        <ul>
          <li>Individuelles Design</li><li>Mobile Optimiert</li><li>Klare Call-to-Actions</li><li>SEO Basis & schnelle Ladezeiten</li><li>Performance Fokus</li>
        </ul>
      </div>
      <div class="service-card">
        <div class="s-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg></div>
        <h3>Tracking & Reporting</h3>
        <p>Wir tracken alles, analysieren die Daten und optimieren kontinuierlich für maximale Transparenz.</p>
        <ul>
          <li>Pixel & Event Tracking Setup</li><li>Monatliches Reporting</li><li>KPIs im Überblick</li><li>Datenbasierte Optimierung</li><li>Strategische Empfehlungen</li>
        </ul>
      </div>
      <div class="service-card">
        <div class="s-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12a9 9 0 009 9 9 9 0 006.36-2.64M21 12a9 9 0 00-9-9 9 9 0 00-6.36 2.64"/><polyline points="21 3 21 9 15 9"/><polyline points="3 21 3 15 9 15"/></svg></div>
        <h3>Retargeting & Optimierung</h3>
        <p>Wir reaktivieren potenzielle Kunden gezielt und holen das Maximum aus deinem Marketing heraus.</p>
        <ul>
          <li>Custom & Lookalike Audiences</li><li>Multi-Channel Retargeting</li><li>A/B Testing & Heatmaps</li><li>CRO Landingpage Optimierung</li><li>Conversion Rate Steigerung</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<div class="glow-div"></div>

<!-- PAKETE -->
<section class="pakete" id="pakete">
  <div class="container">
    <div class="pakete-intro fade-up">
      <div>
        <div class="section-tag">Unsere Pakete</div>
        <h2 class="section-title">Das richtige Paket<br>für dein Business.</h2>
      </div>
      <p class="section-sub">Von kleinen Unternehmen bis zu ambitionierten Brands, die skalieren wollen.</p>
    </div>
    <div class="pakete-grid fade-up">
      <div class="paket">
        <span class="p-badge b-starter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg> Für kleine Unternehmen</span>
        <h3>Starter Paket</h3>
        <p class="paket-sub">Dein Einstieg in professionelles Marketing. Kleines Paket. Großer Start.</p>
        <hr/>
        <ul class="paket-features">
          <li><span class="chk">✓</span>Social Media Content – Feed Posts, Stories, Hashtags</li>
          <li><span class="chk">✓</span>Einfache Ads – Setup, Zielgruppen-Targeting, Optimierung</li>
          <li><span class="chk">✓</span>Basis Community Interaktion</li>
          <li><span class="chk">✓</span>Monatliches Reporting & KPI Überblick</li>
          <li><span class="chk">✓</span>Strategische Empfehlungen</li>
        </ul>
        <a href="#kontakt" class="p-btn p-btn-outline">Jetzt anfragen →</a>
      </div>
      <div class="paket featured">
        <span class="p-badge b-growth"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> Dein Sweet Spot</span>
        <h3>Growth Paket</h3>
        <p class="paket-sub">Die perfekte Kombination aus Strategie, Performance & Design für mehr Anfragen.</p>
        <hr/>
        <ul class="paket-features">
          <li><span class="chk">✓</span>Social Media & Content – Reels, Stories, Community Mgmt.</li>
          <li><span class="chk">✓</span>Performance Ads – Kampagnen, Testing, Conversion Opt.</li>
          <li><span class="chk">✓</span>Conversion-optimierte Landingpage</li>
          <li><span class="chk">✓</span>Tracking & Reporting – Pixel, Events, KPIs</li>
          <li><span class="chk">✓</span>Laufende strategische Betreuung</li>
          <li><span class="chk">✓</span>Datenbasierte Optimierung</li>
        </ul>
        <a href="#kontakt" class="p-btn p-btn-solid">Jetzt anfragen →</a>
      </div>
      <div class="paket">
        <span class="p-badge b-scale"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12"><path d="M2 20h20M4 20V10l8-8 8 8v10"/><path d="M9 20v-6h6v6"/></svg> High Ticket</span>
        <h3>Scale Paket</h3>
        <p class="paket-sub">Maximales Wachstum. Systeme, die skalieren. Für ambitionierte Unternehmen.</p>
        <hr/>
        <ul class="paket-features">
          <li><span class="chk">✓</span>Alles aus dem Growth Paket</li>
          <li><span class="chk">✓</span>AI Lead System – Automation, Funnels, CRM</li>
          <li><span class="chk">✓</span>E-Mail & WhatsApp Automation</li>
          <li><span class="chk">✓</span>Retargeting – Custom Audiences, Multi-Channel</li>
          <li><span class="chk">✓</span>A/B Testing, ROAS & Conversion Steigerung</li>
          <li><span class="chk">✓</span>Pipeline Management & Follow-up</li>
        </ul>
        <a href="#kontakt" class="p-btn p-btn-outline">Jetzt anfragen →</a>
      </div>
    </div>
  </div>
</section>

<div class="glow-div"></div>

<!-- PROZESS -->
<section class="process" id="prozess">
  <div class="container">
    <div class="fade-up" style="text-align:center">
      <div class="section-tag">So arbeiten wir</div>
      <h2 class="section-title">Von der Anfrage zum<br>messbaren Ergebnis.</h2>
    </div>
    <div class="steps fade-up">
      <div class="step"><div class="step-n">01</div><h4>Gespräch</h4><p>Kostenloses Strategiegespräch & Analyse deines Business.</p></div>
      <div class="step"><div class="step-n">02</div><h4>Strategie</h4><p>Individueller Fahrplan für maximale Ergebnisse.</p></div>
      <div class="step"><div class="step-n">03</div><h4>Setup</h4><p>Kampagnen, Systeme & Tracking aufsetzen.</p></div>
      <div class="step"><div class="step-n">04</div><h4>Launch</h4><p>Wir gehen live – erste Ergebnisse in Kürze.</p></div>
      <div class="step"><div class="step-n">05</div><h4>Optimierung</h4><p>Laufende Verbesserung auf Basis von Daten.</p></div>
      <div class="step"><div class="step-n">06</div><h4>Skalierung</h4><p>Wachstum ausbauen & nachhaltig skalieren.</p></div>
    </div>
  </div>
</section>

<div class="glow-div"></div>

<!-- WHY -->
<section class="why">
  <div class="container">
    <div class="why-grid fade-up">
      <div>
        <div class="section-tag">Warum NextLevel</div>
        <h2 class="section-title">Dein System.<br>Dein Wettbewerbsvorteil.</h2>
        <p class="section-sub" style="margin-bottom:2.5rem">Kein generisches Marketing. Wir bauen ein System, das für genau dein Business funktioniert.</p>
        <div class="why-list">
          <div class="why-item"><div class="w-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/></svg></div><div><h4>Ergebnisorientiert</h4><p>Jede Entscheidung basiert auf Daten, nicht auf Bauchgefühl.</p></div></div>
          <div class="why-item"><div class="w-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div><div><h4>Alles aus einer Hand</h4><p>Social Media, Ads, AI-Automation & Webdesign – kein Koordinationsaufwand.</p></div></div>
          <div class="why-item"><div class="w-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></div><div><h4>Persönlicher Service</h4><p>Direkter Ansprechpartner, kein Callcenter, keine langen Wartezeiten.</p></div></div>
          <div class="why-item"><div class="w-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></div><div><h4>Nachhaltiges Wachstum</h4><p>Systeme, die mit deinem Business wachsen – langfristig & profitabel.</p></div></div>
        </div>
      </div>
      <div class="metrics-box">
        <div class="section-tag" style="margin-bottom:1.5rem">Ergebnisse unserer Kunden</div>
        <div class="metric"><div class="m-top">Mehr Anfragen<span>+248%</span></div><div class="m-bar"><div class="m-fill" data-w="85%"></div></div></div>
        <div class="metric"><div class="m-top">Lead Generierung (AI)<span>+237%</span></div><div class="m-bar"><div class="m-fill" data-w="80%"></div></div></div>
        <div class="metric"><div class="m-top">Conversion Rate<span>+62%</span></div><div class="m-bar"><div class="m-fill" data-w="62%"></div></div></div>
        <div class="metric"><div class="m-top">Umsatz<span>+35%</span></div><div class="m-bar"><div class="m-fill" data-w="45%"></div></div></div>
        <div class="metric"><div class="m-top">Niedrigere Kosten pro Lead<span>-40%</span></div><div class="m-bar"><div class="m-fill" data-w="70%"></div></div></div>
        <p style="margin-top:1.8rem;padding-top:1.3rem;border-top:1px solid var(--border);font-size:.72rem;color:var(--muted2)">Durchschnittliche Ergebnisse nach 90 Tagen Zusammenarbeit.</p>
      </div>
    </div>
  </div>
</section>

<div class="glow-div"></div>

<!-- ÜBER UNS -->
<section class="ueber-uns" id="ueber-uns">
  <div class="container">
    <div class="fade-up" style="text-align:center;margin-bottom:3.5rem">
      <div class="section-tag">Wer wir sind</div>
      <h2 class="section-title">Das Team hinter<br>NextLevel Marketing.</h2>
      <p class="section-sub" style="max-width:560px;margin:1rem auto 0">Wir sind keine klassische Agentur. Wir sind Unternehmer, die verstehen, was es bedeutet, Ergebnisse zu liefern – nicht nur Versprechen.</p>
    </div>

    <div class="team-grid fade-up">

      <!-- CEO 1 -->
      <div class="team-card">
        <div class="team-photo-wrap">
          <div class="team-photo-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="52" height="52">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
            <span>Foto folgt</span>
          </div>
        </div>
        <div class="team-info">
          <div class="team-role">Co-Founder & CEO</div>
          <h3 class="team-name">Pino Stoisser</h3>
          <p class="team-bio">Mit einem tiefen Verständnis für digitales Marketing und datengetriebene Strategien bringt Pino die analytische Kraft hinter NextLevel. Sein Fokus liegt darauf, messbare Ergebnisse zu erzielen und Systeme zu bauen, die skalieren.</p>
          <div class="team-tags">
            <span>Strategy</span>
            <span>Performance Ads</span>
            <span>AI Systems</span>
          </div>
          <a href="https://www.instagram.com/marketingbynextlevel/" target="_blank" class="team-ig">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            @marketingbynextlevel
          </a>
        </div>
      </div>

      <!-- CEO 2 -->
      <div class="team-card">
        <div class="team-photo-wrap">
          <div class="team-photo-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="52" height="52">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
            <span>Foto folgt</span>
          </div>
        </div>
        <div class="team-info">
          <div class="team-role">Co-Founder & CEO</div>
          <h3 class="team-name">Patrik Igloi</h3>
          <p class="team-bio">Patrik ist der kreative Kopf hinter NextLevel. Mit seinem Gespür für starke Markenauftritte und wirkungsstarken Content sorgt er dafür, dass Kunden nicht nur gesehen werden – sondern im Gedächtnis bleiben.</p>
          <div class="team-tags">
            <span>Social Media</span>
            <span>Content Creation</span>
            <span>Branding</span>
